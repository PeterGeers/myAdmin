{
  "enabled": false,
  "name": "Run Tests After Spec Task",
  "description": "Runs both backend and frontend unit tests after a spec task is marked complete, ensuring the implementation doesn't break existing functionality.",
  "version": "1",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "runCommand",
    "command": "bash -c 'cd backend && python -m pytest tests/unit/ -x -q --tb=short 2>&1 | tail -n 30' && bash -c 'cd frontend && npx react-scripts test --watchAll=false --ci 2>&1 | tail -n 30'",
    "timeout": 180
  }
}