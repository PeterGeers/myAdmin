{
  "enabled": true,
  "name": "Run Backend Tests After Spec Task",
  "description": "Runs backend pytest unit tests after a spec task is marked complete.",
  "version": "3",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "runCommand",
    "command": "python -m pytest tests/unit/ -x -q --tb=short",
    "timeout": 120
  }
}
