# Frontend Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env files to git!

# ============================================
# AWS Cognito (Authentication)
# ============================================
VITE_COGNITO_USER_POOL_ID=eu-west-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=<your-client-id>
VITE_COGNITO_DOMAIN=<your-app-name>.auth.eu-west-1.amazoncognito.com
VITE_AWS_REGION=eu-west-1

# ============================================
# API Configuration
# ============================================
VITE_API_URL=http://localhost:5000
# For production: https://your-app.railway.app

# ============================================
# OAuth Redirect URLs
# ============================================
VITE_REDIRECT_SIGN_IN=http://localhost:3000/
VITE_REDIRECT_SIGN_OUT=http://localhost:3000/
# For production, add your Railway URL

# ============================================
# Documentation
# ============================================
VITE_DOCS_URL=/docs
# For production: https://your-app.railway.app/docs
